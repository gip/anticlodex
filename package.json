{
  "name": "acx",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @acx/web dev",
    "dev:api": "pnpm --filter @acx/api dev",
    "dev:desktop": "pnpm --filter @acx/desktop dev",
    "dev:desktop:with-api": "ACX_ENABLE_CLAUDE_AGENT=1 pnpm --parallel --filter @acx/api --filter @acx/desktop run dev",
    "build:web": "pnpm --filter @acx/web build",
    "build:api": "pnpm --filter @acx/api build",
    "build:desktop": "pnpm --filter @acx/desktop build",
    "migrate": "pnpm --filter @acx/api migrate"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.13.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4"
}
